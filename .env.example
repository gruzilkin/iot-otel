# Database
DB_USER=user
DB_PASSWORD=secret
DB_NAME=fileserver

# OAuth2 (GitHub). Leave blank to disable login.
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8080/oauth2/callback

# Web
WS_ALLOWED_ORIGINS=          # comma-separated; empty = same-origin only

# OpenTelemetry metrics + logs (unset = disabled; logs also still print to
# stdout). Standard OTEL_* vars apply; the endpoint must be a URL with a scheme
# (e.g. http://collector:4317). Per-signal overrides: OTEL_EXPORTER_OTLP_LOGS_*.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=iot-otel

# Device client (Pi)
TARGET=localhost:50051
BEARER=
TLS=
