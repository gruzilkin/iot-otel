# Database
DB_USER=user
DB_PASSWORD=secret
DB_NAME=fileserver

# OAuth2 (GitHub). Leave blank to disable login (use DEV_LOGIN_USER_ID locally).
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8080/oauth2/callback

# Web
COOKIE_SECURE=false          # true behind HTTPS
WS_ALLOWED_ORIGINS=          # comma-separated; empty = same-origin only
# DEV_LOGIN_USER_ID=1        # dev only: GET /dev-login logs in as this user id

# gRPC TLS (required outside a trusted network)
GRPC_TLS_CERT_FILE=
GRPC_TLS_KEY_FILE=

# OpenTelemetry metrics (unset = disabled). Standard OTEL_* vars apply.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=iot-otel

# Device client (Pi)
TARGET=localhost:50051
BEARER=
TLS=
